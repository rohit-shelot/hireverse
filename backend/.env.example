# ============================================================
# HireVerse Backend - Environment Variables Example
# ============================================================
# Copy this file to set environment variables when running locally
# or inject them as secrets in your cloud deployment (Railway, Render, etc.)
# ============================================================

# Server
PORT=8081

# Database
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/campus_placement?createDatabaseIfNotExist=true
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=your_db_password_here

# JWT
JWT_SECRET=your_very_long_random_secret_key_at_least_32_chars

# JPA
HIBERNATE_DDL_AUTO=update
SHOW_SQL=true

# Email (Gmail SMTP with App Password)
SPRING_MAIL_HOST=smtp.gmail.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=your_gmail@gmail.com
SPRING_MAIL_PASSWORD=your_gmail_app_password

# Admin account seeded on first run
ADMIN_EMAIL=admin@hireverse.com
ADMIN_PASSWORD=your_admin_password_here
